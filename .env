# Database Configuration
# Prefer DATABASE_URL in deployment. Local development can use the DB_* fields below.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_campus_db
DB_USER=postgres
DB_PASSWORD=smartAF

# Security / Authentication
JWT_SECRET=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXP_HOURS=24

# Flask / App Settings
SECRET_KEY=change-this-flask-secret
FLASK_ENV=development
FLASK_DEBUG=true
APP_NAME=Smart Campus Intelligence System
APP_URL=http://localhost:5000
LOG_LEVEL=INFO
STRICT_STARTUP_VALIDATION=false
TRUST_PROXY_COUNT=1

# Database Pooling
DB_POOL_MINCONN=1
DB_POOL_MAXCONN=10

# Auth Cookie
AUTH_COOKIE_NAME=smart_campus_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=

# Email / SMTP (for OTP password recovery)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@smartcampus.com

# Gemini AI Support
GEMINI_API_KEY=AIzaSyAfHGNYPw9qvQFhOCItRyr0btBytkY64RA
GEMINI_MODEL=gemini-2.0-flash

