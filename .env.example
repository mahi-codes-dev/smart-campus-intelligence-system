# Database Configuration
# Prefer DATABASE_URL in deployment. Local development can use the DB_* fields below.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_campus_db
DB_USER=postgres
DB_PASSWORD=change_me

# Security / Authentication
JWT_SECRET=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXP_HOURS=24

# Flask / App Settings
SECRET_KEY=change-this-flask-secret
FLASK_ENV=development
FLASK_DEBUG=true
APP_NAME=Smart Campus Intelligence System
APP_URL=http://localhost:5000
