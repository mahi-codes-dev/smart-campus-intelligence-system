# ============================================================
# Smart Campus Intelligence System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# For Render / production: use DATABASE_URL (single connection string).
# For local dev: use the DB_* variables below.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_campus_db
DB_USER=postgres
DB_PASSWORD=change_me_to_a_strong_password
DB_CONNECT_TIMEOUT=10
DB_SSL_MODE=                # Set to require on Render/Postgres with SSL

# Database connection pool (tune per Render plan)
DB_POOL_MINCONN=1
DB_POOL_MAXCONN=10

# --- Security ---
# IMPORTANT: Use a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXP_HOURS=24
SECRET_KEY=change-this-to-another-long-random-secret

# --- Flask ---
FLASK_ENV=development        # Set to "production" on Render
FLASK_DEBUG=true             # Set to "false" in production
APP_NAME=Smart Campus Intelligence System
APP_URL=http://localhost:5000
LOG_LEVEL=INFO
STRICT_STARTUP_VALIDATION=false  # Set to "true" in production
RELEASE_VERSION=dev
RELEASE_COMMIT=

# --- Proxy / HTTPS ---
# Number of trusted proxy hops (1 for Render / most PaaS)
TRUST_PROXY_COUNT=1
WEB_CONCURRENCY=2
GUNICORN_THREADS=2

# --- Auth Cookie ---
AUTH_COOKIE_NAME=smart_campus_token
AUTH_COOKIE_SECURE=false     # Set to "true" when deployed on HTTPS
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=          # Leave blank for same-domain
CORS_ALLOWED_ORIGINS=        # Optional comma-separated origins for future SPA split

# --- Email / SMTP (for OTP password recovery) ---
# Use Gmail App Password if using Gmail (not your regular password)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=               # e.g. yourname@gmail.com
SMTP_PASSWORD=               # Gmail App Password (16 chars, no spaces)
MAIL_DEFAULT_SENDER=noreply@smartcampus.com

# --- Gemini AI (optional — powers the AI assistant) ---
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
